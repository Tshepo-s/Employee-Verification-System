@* This view uses a custom, non-authenticated layout with the separate fbar header and footer. *@
@model List<Log>
@{
    // Setting Layout to null makes this page completely independent of the main _Layout.cshtml
    Layout = null;
    ViewData["Title"] = "About Employee Verification | National Treasury";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    @* External Assets *@
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-SnH5WK+bZxgPHs44uWWIx+LLMD/CDQ+09iWbuS0GgB6g/X9c/fB2C7H5D2nLhLw2pD/mNlA2O/0y7W3Z4H+Ww==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" /> @* Optional animation library *@

    <style>
        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f8f9fa; /* Light background outside hero/footer */
        }

        /* --- Custom Header (fbar) Styles --- */
        .fbar {
            background-color: #006400; /* Dark Green */
            color: white;
            padding: 1rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

            .fbar img {
                height: 35px;
                width: auto;
                margin-right: 12px;
            }

        .fbar-title {
            display: flex;
            align-items: center;
            font-size: 1.2rem;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .fbar-links a {
            color: white;
            margin-left: 20px;
            font-weight: 500;
            text-decoration: none;
            transition: color 0.2s ease-in-out;
        }

            .fbar-links a:hover {
                color: #d4edda; /* Light Green hover accent */
                text-decoration: none;
            }

        /* --- About Us Page Enhancements --- */
        .about-hero {
            background: linear-gradient(135deg, #166534 0%, #064e3b 100%); /* Dark green gradient */
            color: white;
            padding: 80px 20px;
            margin-bottom: 3rem;
            border-bottom-left-radius: 15px;
            border-bottom-right-radius: 15px;
            box-shadow: 0 8px 15px rgba(0, 0, 0, 0.2);
        }

            .about-hero h1 {
                font-weight: 700;
                margin-bottom: 15px;
                text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
            }

        .section-heading {
            font-weight: 700;
            color: #166534; /* Dark green for section headings */
        }

        .section-divider {
            border: 0;
            height: 3px;
            background: linear-gradient(to right, #a7f3d0, #16a34a, #a7f3d0); /* Green gradient divider */
            width: 80px;
            margin: 0 auto 3rem auto;
            border-radius: 50%;
            opacity: 0.7;
        }

        .card {
            border-radius: 10px;
            transition: transform 0.2s ease-in-out;
        }

            .card:hover {
                transform: translateY(-5px);
            }

        .card-title {
            font-weight: 600;
        }

        .list-group-item {
            padding-left: 0;
            background-color: transparent !important;
        }

            .list-group-item i {
                font-size: 1.1em;
            }

        .custom-table thead {
            background-color: #166534 !important;
        }

        .custom-table th {
            border-color: #0c4a3b !important;
        }

        .custom-table tbody tr:hover {
            background-color: #e0f2f1;
        }

        .custom-table .badge {
            font-weight: 500;
            padding: 0.4em 0.7em;
            border-radius: 0.35rem;
        }

        /* --- Footer Styles --- */
        .site-footer {
            background-color: #006400; /* Dark Green background for the entire footer area */
            color: #ffffff;
            padding: 40px 0 20px;
            font-size: 0.9rem;
            margin-top: 4rem; /* Add margin above the footer to separate from content */
        }

        .footer-logo {
            height: 50px;
            margin-bottom: 15px;
        }

        .footer-heading {
            color: #ffffff;
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 15px;
            border-bottom: 2px solid #d4edda;
            display: inline-block;
            padding-bottom: 5px;
        }

        .footer-links li {
            margin-bottom: 8px;
        }

        .footer-links a, .footer-contact p, .footer-contact a {
            color: #d4edda;
            text-decoration: none;
        }

            .footer-links a:hover, .footer-contact a:hover {
                color: #ffffff;
                text-decoration: underline;
            }

        .social-icons a {
            color: #ffffff;
            font-size: 1.3rem;
            margin-right: 15px;
            transition: color 0.3s;
        }

            .social-icons a:hover {
                color: #d4edda;
            }

        .copyright-bar {
            border-top: 1px solid #004c00;
            padding-top: 15px;
            margin-top: 20px;
            text-align: center;
            color: #d4edda;
        }
    </style>
</head>

<body>
    @* --- START: Custom Header (fbar) --- *@
    <header class="fbar">
        <div class="fbar-title">
            <img src="@Url.Content("~/images/thumb_2_treasury.png")" alt="National Treasury Logo" />
            <span>Employee Verification</span>
        </div>

        <div class="fbar-links">
            @* These links direct to the Login and Register actions on your Home Controller *@
            <a href="@Url.Action("Login", "Home")">Login</a>
            <a href="@Url.Action("Create", "Home")">Register</a>
        </div>
    </header>
    @* --- END: Custom Header (fbar) --- *@


    @* --- START: Beautiful About Us Content --- *@
    <div class="about-hero text-center py-5 mb-5">
        <h1 class="display-4 text-white animate__animated animate__fadeInDown">Empowering Secure Government Operations</h1>
        <p class="lead text-white-50 animate__animated animate__fadeInUp">The National Treasury's commitment to efficiency and transparency.</p>
    </div>

    <div class="container my-5">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <h2 class="text-center mb-4 section-heading">About the Employee Verification System</h2>
                <hr class="section-divider mb-5">

                <div class="card mb-5 shadow-sm border-0">
                    <div class="card-body p-4">
                        <h3 class="card-title text-success mb-3"><i class="fas fa-clipboard-check me-2"></i>Our Mandate: Upholding Integrity</h3>
                        <p class="card-text">The <strong>Employee Verification System</strong> is a pivotal application developed for the <strong>National Treasury</strong> of the Republic of South Africa. Our core mandate is to **fortify the integrity and operational efficiency of public finance management** by offering a meticulously secure, highly reliable, and fully auditable framework for verifying the employment status and critical details of government personnel.</p>
                        <p class="card-text">This initiative underscores our dedication to maintaining the highest standards within the public sector, ensuring every verification contributes to a robust and accountable financial ecosystem.</p>
                    </div>
                </div>

                <div class="card mb-5 shadow-sm border-0">
                    <div class="card-body p-4">
                        <h3 class="card-title text-success mb-3"><i class="fas fa-lightbulb me-2"></i>Our Purpose: Driving Efficiency & Trust</h3>
                        <p class="card-text">Developed in harmony with the National Treasury's unwavering commitment to <strong>fiscal discipline, comprehensive transparency, and exemplary good governance</strong>, this system was meticulously crafted to address key operational needs:</p>
                        <ul class="list-group list-group-flush mb-4">
                            <li class="list-group-item border-0"><i class="fas fa-check-circle text-primary me-2"></i> <strong>Ensure Unwavering Accountability:</strong> Provide instant confirmation of employee status, critically supporting compliance, rigorous audit processes, and streamlined human resource management.</li>
                            <li class="list-group-item border-0"><i class="fas fa-rocket text-info me-2"></i> <strong>Streamline Operational Workflows:</strong> Revolutionize manual verification methods by introducing a digital, real-time, and centrally managed process, resulting in significant savings of time and invaluable resources.</li>
                            <li class="list-group-item border-0"><i class="fas fa-shield-alt text-danger me-2"></i> <strong>Elevate Data Security:</strong> Implement robust protection for sensitive personnel data through an advanced, role-based authentication model, guaranteeing that access to information is strictly limited to authorized administrators and auditors.</li>
                        </ul>
                    </div>
                </div>

                <h3 class="text-center mb-4 section-heading">System Roles & Capabilities</h3>
                <hr class="section-divider mb-5">

                <div class="table-responsive mb-5">
                    <table class="table table-hover table-bordered table-striped custom-table shadow-sm">
                        <thead class="bg-primary text-white">
                            <tr>
                                <th scope="col">Feature Area</th>
                                <th scope="col">Core Objective</th>
                                <th scope="col">Authorized User Roles</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><strong>Verifications (Homepage)</strong></td>
                                <td>Effortlessly search and confirm employee employment status.</td>
                                <td><span class="badge bg-success">All Users</span> (Admin, Auditor, Standard User)</td>
                            </tr>
                            <tr>
                                <td><strong>Employee Management</strong></td>
                                <td>Centralized viewing and administration of the employee database.</td>
                                <td><span class="badge bg-warning text-dark">Admin</span> &amp; <span class="badge bg-info text-dark">Auditor</span></td>
                            </tr>
                            <tr>
                                <td><strong>Registered Users Overview</strong></td>
                                <td>Comprehensive oversight and management of application user accounts and assigned roles.</td>
                                <td><span class="badge bg-info text-dark">Auditor</span> (for enhanced governance and control)</td>
                            </tr>
                            <tr>
                                <td><strong>User Profile & Settings</strong></td>
                                <td>Personalized access to user-specific settings and security information.</td>
                                <td><span class="badge bg-warning text-dark">Admin</span> &amp; <span class="badge bg-primary">Standard User</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="text-center mt-5">
                    <h3 class="section-heading text-success">Our Ongoing Commitment</h3>
                    <p class="lead">We are steadfast in our dedication to upholding the <strong>highest standards of data integrity, privacy, and operational security</strong>. This advanced system stands as a testament to the National Treasury's continuous pursuit of a modern, efficient, and digitized public service that unequivocally prioritizes accountability and the effective stewardship of public resources.</p>
                    <p class="text-muted mt-4"><small><em>For further official information and detailed services of the National Treasury, please visit the <a href="https://www.treasury.gov.za" target="_blank" class="text-success fw-bold">official National Treasury website</a>.</em></small></p>
                </div>
            </div>
        </div>
    </div>
    @* --- END: Beautiful About Us Content --- *@

    @* --- START: Integrated Footer --- *@
    <footer class="site-footer">
        <div class="container">
            <div class="row">

                <div class="col-md-4 mb-4">
                    <img src="@Url.Content("~/images/thumb_2_treasury.png")" alt="National Treasury Logo" class="footer-logo" />
                    <p>Ensuring economic stability and fiscal discipline of South Africa through effective financial management.</p>
                </div>

                <div class="col-md-2 col-sm-6 mb-4">
                    <h5 class="footer-heading">Quick Links</h5>
                    <ul class="list-unstyled footer-links">
                        <li><a href="#">Official Website</a></li>
                        <li><a href="#">Legislation</a></li>
                        <li><a href="#">Publications</a></li>
                        <li><a href="#">Sitemap</a></li>
                    </ul>
                </div>

                <div class="col-md-3 col-sm-6 mb-4">
                    <h5 class="footer-heading">Resources</h5>
                    <ul class="list-unstyled footer-links">
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="#">Terms of Use</a></li>
                        <li><a href="#">Accessibility</a></li>
                        <li><a href="#">FAQ</a></li>
                    </ul>
                </div>

                <div class="col-md-3 mb-4 footer-contact">
                    <h5 class="footer-heading">Contact Us</h5>
                    <p><i class="fas fa-map-marker-alt me-2"></i> 240 Madiba St, Pretoria, 0001</p>
                    <p><i class="fas fa-phone me-2"></i> +27 12 315 5944</p>
                    <p><i class="fas fa-envelope me-2"></i> <a href="mailto:info@treasury.gov.za">info@treasury.gov.za</a></p>

                    <div class="social-icons mt-3">
                        <a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" aria-label="Twitter"><i class="fab fa-x-twitter"></i></a>
                        <a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>

            </div>

            <div class="row">
                <div class="col-12">
                    <div class="copyright-bar">
                        &copy; @DateTime.Now.Year National Treasury. All rights reserved. | Republic of South Africa
                    </div>
                </div>
            </div>
        </div>
    </footer>
    @* --- END: Integrated Footer --- *@

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>