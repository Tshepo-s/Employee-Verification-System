@model List<Log>

@{
    Layout = null;
    ViewData["Title"] = "Employee Verification | National Treasury";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-SnH5WK+bZxgPHs44uWWIx+LLMD/CDQ+09iWbuS0GgB6g/X9c/fB2C7H5D2nLhLw2pD/mNlA2O/0y7W3Z4H+Ww==" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <style>
        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f8f9fa;
        }

        /* --- Updated App Bar (Header) Styles --- */
        .fbar {
            /* Restored Dark Green */
            background-color: #006400;
            color: white;
            padding: 1rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

            .fbar img {
                height: 35px;
                width: auto;
                margin-right: 12px;
            }

        .fbar-title {
            display: flex;
            align-items: center;
            font-size: 1.2rem;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .fbar-links a {
            color: white;
            margin-left: 20px;
            font-weight: 500;
            text-decoration: none;
            transition: color 0.2s ease-in-out;
        }

            .fbar-links a:hover {
                /* Light Green hover accent */
                color: #d4edda;
                text-decoration: none;
            }

        .hero-section {
            position: relative;
            background: url('@Url.Content("~/images/code.jpg")') no-repeat center center/cover;
            min-height: calc(100vh - 67px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3rem 1.5rem;
        }

        .overlay {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.55);
        }

        .content {
            position: relative;
            z-index: 2;
            max-width: 900px;
            margin: auto;
            color: #f8f9fa;
            line-height: 1.7;
            text-align: justify;
        }

            .content h2 {
                text-align: center;
                font-weight: 700;
                margin-bottom: 1.5rem;
                color: #ffffff;
            }

        /* --- Footer Styles --- */
        .site-footer {
            /* Restored Dark Green */
            background-color: #006400;
            color: #ffffff;
            padding: 40px 0 20px;
            font-size: 0.9rem;
        }

        .footer-logo {
            height: 50px;
            margin-bottom: 15px;
        }

        .footer-heading {
            color: #ffffff;
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 15px;
            /* Accent color is now a lighter green for visibility on the dark green background */
            border-bottom: 2px solid #d4edda;
            display: inline-block;
            padding-bottom: 5px;
        }

        .footer-links li {
            margin-bottom: 8px;
        }

        .footer-links a, .footer-contact p, .footer-contact a {
            color: #d4edda; /* Light green text for high contrast */
            text-decoration: none;
        }

            .footer-links a:hover, .footer-contact a:hover {
                color: #ffffff; /* White hover */
                text-decoration: underline;
            }

        .social-icons a {
            color: #ffffff;
            font-size: 1.3rem;
            margin-right: 15px;
            transition: color 0.3s;
        }

            .social-icons a:hover {
                color: #d4edda; /* Light Green hover */
            }

        .copyright-bar {
            border-top: 1px solid #004c00; /* Darker green line */
            padding-top: 15px;
            margin-top: 20px;
            text-align: center;
            color: #d4edda;
        }
    </style>
</head>

<body>
    <header class="fbar">
        <div class="fbar-title">
            <img src="@Url.Content("~/images/thumb_2_treasury.png")" alt="National Treasury Logo" />
            <span>Employee Verification</span>
        </div>

        <div class="fbar-links">
            <a href="@Url.Action("Login", "Home")">Login</a>
            <a href="@Url.Action("Create", "Home")">Register</a>
        </div>
    </header>

    <section class="hero-section">
        <div class="overlay"></div>
        <main class="content">
            <h2>About the National Treasury</h2>
            <p>
                The National Treasury plays a vital role in ensuring the economic stability and fiscal discipline of South Africa.
                It oversees government expenditure, manages national revenue, and formulates policies aimed at sustainable economic
                growth. Its mandate includes promoting accountability and transparency in public finances while supporting efficient
                allocation of resources across all government departments and state entities.
            </p>
            <p>
                Through effective budgeting and financial management, the National Treasury works to strengthen public confidence in
                government institutions. It collaborates with key sectors to foster investment, employment, and equitable service delivery.
                The Treasury’s strategic leadership ensures that fiscal policy supports inclusive economic growth and upholds the principles
                of good governance across all spheres of the public sector.
            </p>
        </main>
    </section>

    <footer class="site-footer">
        <div class="container">
            <div class="row">

                <div class="col-md-4 mb-4">
                    <img src="@Url.Content("~/images/thumb_2_treasury.png")" alt="National Treasury Logo" class="footer-logo" />
                    <p>Ensuring economic stability and fiscal discipline of South Africa through effective financial management.</p>
                </div>

                <div class="col-md-2 col-sm-6 mb-4">
                    <h5 class="footer-heading">Quick Links</h5>
                    <ul class="list-unstyled footer-links">
                        <li><a href="#">Official Website</a></li>
                        <li><a href="#">Legislation</a></li>
                        <li><a href="#">Publications</a></li>
                             <li>

     <a href="@Url.Action("About", "Home")">About</a>

 </li>
                       
                    </ul>
                </div>

                <div class="col-md-3 col-sm-6 mb-4">
                    <h5 class="footer-heading">Resources</h5>
                    <ul class="list-unstyled footer-links">
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="#">Terms of Use</a></li>
                        <li><a href="#">Accessibility</a></li>
                        <li><a href="#">FAQ</a></li>
                    </ul>
                </div>

                <div class="col-md-3 mb-4 footer-contact">
                    <h5 class="footer-heading">Contact Us</h5>
                    <p><i class="fas fa-map-marker-alt me-2"></i> 240 Madiba St, Pretoria, 0001</p>
                    <p><i class="fas fa-phone me-2"></i> +27 12 315 5944</p>
                    <p><i class="fas fa-envelope me-2"></i> <a href="mailto:info@treasury.gov.za">info@treasury.gov.za</a></p>

                    <div class="social-icons mt-3">
                        <a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" aria-label="Twitter"><i class="fab fa-x-twitter"></i></a>
                        <a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>

            </div>

            <div class="row">
                <div class="col-12">
                    <div class="copyright-bar">
                        &copy; @DateTime.Now.Year National Treasury. All rights reserved. | Republic of South Africa
                    </div>
                </div>
            </div>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>