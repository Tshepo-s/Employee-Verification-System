@model LEAVE_SYSTEM.Models.LoginViewModel;

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Employee Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="flex items-center justify-center py-12">
    <div class="register-form-container w-full max-w-2xl bg-white p-8 md:p-12 rounded-2xl shadow-xl border border-gray-200">
        <div class="text-center mb-10">
            <h1 class="text-4xl font-bold text-gray-800 tracking-tight">Employee Account Login</h1>
            <p class="mt-2 text-lg text-gray-500">
                Please fill in the details below to login.
            </p>
        </div>

        <form asp-action="Login" method="post" class="space-y-6">
            <div asp-validation-summary="ModelOnly" class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg relative" role="alert"></div>



          

            <div>
                <label asp-for="EmailAddress" class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
                <div class="mt-1 input-wrapper">
                    <span class="input-icon"><i class="fas fa-envelope"></i></span>
                    <input asp-for="EmailAddress" type="text" class="form-control-padding block w-full rounded-md border-gray-300 shadow-sm transition duration-150 ease-in-out focus:border-green-500 focus:ring-green-500 sm:text-sm" aria-required="true" placeholder="e.g., tshepo@example.com" />
                    <span asp-validation-for="EmailAddress" class="text-red-500 text-sm mt-1 block"></span>
                </div>
            </div>



            <div>
                <label asp-for="Password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                <div class="mt-1 input-wrapper">
                    <span class="input-icon"><i class="fas fa-lock"></i></span>
                    <input asp-for="Password" type="password" class="form-control-padding block w-full rounded-md border-gray-300 shadow-sm transition duration-150 ease-in-out focus:border-green-500 focus:ring-green-500 sm:text-sm" aria-required="true" placeholder="Password" />
                    <span asp-validation-for="Password" class="text-red-500 text-sm mt-1 block"></span>
                </div>
            </div>





            <button id="registerSubmit" type="submit" class="w-full py-3 px-4 rounded-md text-white font-semibold shadow-md btn-success-green">
                Login
            </button>
            <p class="mt-2 text-lg text-gray-500">
                Forgot Your Password?
                <a asp-action="ResetPassword" style="font-weight:600;font-style:bold">Reset</a>

            </p>
            <p class="mt-2 text-lg text-gray-500">
                Don't have an account yet?
                <a asp-action="Create" style="font-weight:600;font-style:bold">Register</a>

            </p>


        </form>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>
